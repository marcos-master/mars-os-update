  "lever_logic": {
    "type": "bmw_gws_toggle",
    "input": {
      "id": 407,
      "lever_byte": 2,
      "button_byte": 3,
      "center": 14,
      "manual_center": 126
    },
    "positions": {
      "0x0E": "Center",
      "0x1E": "Up_R",
      "0x2E": "Up_P",
      "0x3E": "Down_D",
      "0x7E": "Side_S",
      "0x5E": "Manual_Down",
      "0x6E": "Manual_Up"
    },
    "buttons": {
      "park_mask": 1,
      "unlock_mask": 2
    },
    "variables": {
      "current_gear": "P",
      "manual_gear": 1,
      "previous_lever_position": 14,
      "current_lever_position": 14,
      "lever_returned_to_center": true,
      "lever_returned_to_manual_center": true,
      "toggle_timeout_ms": 120
    },
    "rules": [
      {
        "name": "Unlock P to N",
        "when": {
          "gear": "P",
          "lever": 14,
          "button_mask": 2
        },
        "set": {
          "gear": "N"
        }
      },
      {
        "name": "Park button",
        "when": {
          "lever": 14,
          "button_mask": 1
        },
        "set": {
          "gear": "P"
        }
      },
      {
        "name": "Up toggle",
        "on_return_to": 14,
        "previous_lever": 30,
        "transitions": [
          {
            "from": "N",
            "to": "R"
          },
          {
            "from": "D",
            "to": "N"
          },
          {
            "from": "M*",
            "to": "N"
          },
          {
            "from": "*",
            "to": "N"
          }
        ]
      },
      {
        "name": "Up plus toggle to park",
        "on_return_to": 14,
        "previous_lever": 46,
        "set": {
          "gear": "P"
        }
      },
      {
        "name": "Down toggle",
        "on_return_to": 14,
        "previous_lever": 62,
        "transitions": [
          {
            "from": "N",
            "to": "D"
          },
          {
            "from": "R",
            "to": "N"
          },
          {
            "from": "M*",
            "to": "D"
          },
          {
            "from": "*",
            "to": "D"
          }
        ]
      },
      {
        "name": "Side toggle",
        "on_return_to": 14,
        "previous_lever": 126,
        "transitions": [
          {
            "from": "D",
            "to": "M1",
            "manual_gear": 1
          },
          {
            "from": "M*",
            "to": "D"
          },
          {
            "from": "*",
            "to": "D"
          }
        ]
      },
      {
        "name": "Manual minus",
        "when_state_prefix": "M",
        "on_return_to": 126,
        "previous_lever": 94,
        "manual_delta": -1,
        "min": 1,
        "max": 8,
        "set_gear_from_manual": true
      },
      {
        "name": "Manual plus",
        "when_state_prefix": "M",
        "on_return_to": 126,
        "previous_lever": 110,
        "manual_delta": 1,
        "min": 1,
        "max": 8,
        "set_gear_from_manual": true
      }
    ],
    "display": {
      "widget": "gear",
      "format": "{gear}",
      "manual_format": "M{manual_gear}"
    }
  }
