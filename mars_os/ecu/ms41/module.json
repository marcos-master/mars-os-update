{
"name": "EDC15 Toolbox",
"version": "0.2",
"author": "MARS OS",
"transport": "KLINE",
"ecu_family": "EDC15",
"default_baud": 10400,
"high_speed_baud": 124800,

"files": {
"read_flash_output": "edc15rd.skf",
"temp_info_file": "temp.bin",
"loader_file": "edc15_loader.bin"
},

"ecu_types": [
{
"name": "EDC15P",
"id": 0,
"key1": "0xDA1C",
"key2": "0xF781",
"loader_profile": "edc15p"
},
{
"name": "EDC15V",
"id": 1,
"key1": "0x508D",
"key2": "0xA647",
"loader_profile": "edc15v"
},
{
"name": "EDC15VM+",
"id": 2,
"key1": "0xF25E",
"key2": "0x6533",
"loader_profile": "edc15vm"
}
],

"menu": [
{
"title": "Read Info",
"action": "read_info"
},
{
"title": "Read Flash",
"action": "read_flash"
},
{
"title": "Write Flash",
"action": "write_flash"
},
{
"title": "Write ORI",
"action": "write_ori"
},
{
"title": "Write MOD",
"action": "write_mod"
},
{
"title": "Add To DB",
"action": "add_db"
}
],

"actions": {
"connect": {
"title": "Connect EDC15",
"steps": [
{
"type": "kline_fast_init",
"baud": 10400,
"wake": "81 01 F1 81 F4"
},
{
"type": "expect_any",
"responses": [
"83 01 7F 00 13",
"83 F1 01 C1 6B 8F"
]
},
{
"type": "send",
"label": "Start diagnostic session",
"data": "82 01 F1 10 85"
},
{
"type": "expect",
"data": "83 F1 01 50 85"
},
{
"type": "send",
"label": "Request speed change",
"data": "03 10 85 87"
},
{
"type": "expect",
"data": "03 50 85 87"
},
{
"type": "change_baud",
"baud": 124800
},
{
"type": "security_access",
"label": "Seed Key Auth",
"seed_request": "03 27 41 00",
"algorithm": "edc15_seed_key"
},
{
"type": "send_loader",
"loader": "edc15_loader.bin",
"profile_from_ecu_type": true
}
]
},

```
"read_info": {
  "title": "Read ECU Info",
  "steps": [
    {
      "type": "run_action",
      "action": "connect"
    },
    {
      "type": "read_memory",
      "label": "Reading info area",
      "start": "0x72000",
      "end": "0x77000",
      "block_size": 254,
      "output": "temp.bin"
    },
    {
      "type": "search_ascii",
      "file": "temp.bin",
      "patterns": ["EDC", "TDI"],
      "offset_before": 20,
      "fields": [
        {
          "name": "SW",
          "offset": 0,
          "length": 11
        },
        {
          "name": "Engine",
          "offset": 12,
          "length": 11
        },
        {
          "name": "HW",
          "offset": 43,
          "length": 11
        },
        {
          "name": "SW Date",
          "offset": 77,
          "length": 5
        }
      ]
    },
    {
      "type": "close_ecu"
    }
  ]
},

"read_flash": {
  "title": "Read Flash",
  "steps": [
    {
      "type": "run_action",
      "action": "connect"
    },
    {
      "type": "read_memory",
      "label": "Reading flash",
      "start": "0x00000",
      "end": "0x7FEE2",
      "block_size": 254,
      "output": "edc15rd.skf"
    },
    {
      "type": "close_ecu"
    }
  ]
},

"write_flash": {
  "title": "Write Flash",
  "steps": [
    {
      "type": "require_file",
      "file": "edc15rd.skf"
    },
    {
      "type": "run_action",
      "action": "connect"
    },
    {
      "type": "send",
      "label": "Erase flash",
      "data": "02 A5 0F B6"
    },
    {
      "type": "expect",
      "data": "01 76"
    },
    {
      "type": "wait",
      "ms": 4000
    },
    {
      "type": "expect",
      "data": "01 76"
    },
    {
      "type": "write_memory",
      "label": "Writing boot",
      "start": "0x7C000",
      "end": "0x7FFFF",
      "block_size": 250,
      "source": "edc15rd.skf"
    },
    {
      "type": "write_memory",
      "label": "Writing flash",
      "start": "0x00000",
      "end": "0x7BFFF",
      "block_size": 250,
      "source": "edc15rd.skf"
    },
    {
      "type": "close_ecu"
    }
  ]
},

"write_ori": {
  "title": "Write ORI",
  "steps": [
    {
      "type": "select_db_file",
      "folder": "ORI",
      "target": "edc15rd.skf"
    },
    {
      "type": "run_action",
      "action": "write_flash"
    }
  ]
},

"write_mod": {
  "title": "Write MOD",
  "steps": [
    {
      "type": "select_db_file",
      "folder": "MOD",
      "target": "edc15rd.skf"
    },
    {
      "type": "run_action",
      "action": "write_flash"
    }
  ]
},

"add_db": {
  "title": "Add File To DB",
  "steps": [
    {
      "type": "require_file",
      "file": "edc15rd.skf"
    },
    {
      "type": "scan_ecu_info",
      "file": "edc15rd.skf",
      "patterns": ["EDC", "TDI"],
      "start": "0x00000",
      "end": "0x5000",
      "offset_before": 20
    },
    {
      "type": "create_db_entry",
      "source": "edc15rd.skf",
      "ori_folder": "ORI",
      "mod_folder": "MOD"
    }
  ]
}
```

